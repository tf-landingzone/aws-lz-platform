    "deny_regions": {
      "name": "DenyOutsideAllowedRegions",
      "description": "Restrict to us-east-1 and us-west-2 only",
      "content_file": "policies/scp_deny_regions.json",
      "target_ids": []
    },
    "deny_root": {
      "name": "DenyRootAccount",
      "description": "Deny all actions by root user in member accounts",
      "content_file": "policies/scp_deny_root.json",
      "target_ids": []
    },
    "security_guardrails": {
      "name": "SecurityGuardrails",
      "description": "Prevent disabling of security services and account operations",
      "content_file": "policies/scp_security_guardrails.json",
      "target_ids": []
