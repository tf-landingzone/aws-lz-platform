    "auditors": {
      "display_name": "AWS-Auditors"
    },
    "readonly": {
      "display_name": "AWS-ReadOnly"
    }
  },
  "permission_sets": {
    "admin": {
      "name": "AdministratorAccess",
      "description": "Full admin access for platform team",
      "session_duration": "PT4H",
      "aws_managed_policies": [
        "arn:aws:iam::aws:policy/AdministratorAccess"
      ]
    },
    "developer": {
      "name": "DeveloperAccess",
      "description": "Power user access for developers",
      "session_duration": "PT8H",
      "aws_managed_policies": [
        "arn:aws:iam::aws:policy/PowerUserAccess"
      ]
    },
    "readonly": {
      "name": "ReadOnlyAccess",
      "description": "Audit read-only access",
      "session_duration": "PT12H",
      "aws_managed_policies": [
        "arn:aws:iam::aws:policy/ReadOnlyAccess"
      ]
    },
    "security_audit": {
      "name": "SecurityAudit",
      "description": "Security audit access",
      "session_duration": "PT12H",
      "aws_managed_policies": [
        "arn:aws:iam::aws:policy/SecurityAudit"
      ]
    }
  },
