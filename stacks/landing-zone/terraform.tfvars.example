################################################################################
# Landing Zone - Example Configuration
################################################################################
# Copy this file to terraform.tfvars and customize for your organization.
# Every section is optional — only configure what you need.
################################################################################

# ── Global Settings ──────────────────────────────────────────────────────────

org            = "acme"
program        = "lz"
primary_region = "us-east-1"
owner          = "platform-team"
cost_center    = "CC-1234"

extra_tags = {
  Environment = "management"
  Compliance  = "SOC2"
}

# ── Feature Flags ────────────────────────────────────────────────────────────
# Enable/disable entire modules — safe to start with a subset and expand later.

enable_organizations     = true
enable_governance        = true
enable_identity_center   = true
enable_security_baseline = true
enable_budget_alerts     = true

# ── Organizations ────────────────────────────────────────────────────────────

manage_organization = false   # Set true only if Terraform should own the Organization

organizational_units = {
  security = {
    name = "Security"
  }
  infrastructure = {
    name = "Infrastructure"
  }
  workloads = {
    name = "Workloads"
  }
  sandbox = {
    name = "Sandbox"
  }
  # Nested OUs under Workloads
  workloads_prod = {
    name       = "Production"
    parent_key = "workloads"
  }
  workloads_staging = {
    name       = "Staging"
    parent_key = "workloads"
  }
  workloads_dev = {
    name       = "Development"
    parent_key = "workloads"
  }
}

